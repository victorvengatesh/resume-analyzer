# ─────────────────────────────────────────────────────────────────────────────
# Smart Resume Analyzer — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider ──────────────────────────────────────────────────────────────
# Get your API Key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkeychangeinproduction
# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Authentication ────────────────────────────────────────────────────────────
# Set to "true" in production to enforce authentication on all protected routes
ENABLE_AUTH=false
ENABLE_USAGE_LIMITS=false
ENABLE_ANALYTICS=false

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Resume Analyzer
# "demo" | "production"
APP_MODE=demo
APP_VERSION=1.0.0

# ── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite:///./resume_ai.db
# Production (PostgreSQL) — uncomment and set:
# DATABASE_URL=postgresql://user:password@host:5432/resume_ai

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
# Maximum file size in bytes (default: 10 MB)
MAX_FILE_BYTES=10485760
# Enable OCR for scanned PDFs (requires pytesseract + Pillow)
USE_OCR=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend URL in production to restrict CORS
FRONTEND_URL=http://localhost:3000

# ── Processing ────────────────────────────────────────────────────────────────
# Number of concurrent workers for batch resume processing
MAX_WORKERS=10
ROLE_SKILLS_FILE=./role_skills.json
