# Smart Resume Analyzer — Frontend Environment Variables
# Copy this file to .env and fill in the values

# ── Backend API URL (REQUIRED for production) ─────────────────────
# Local development: leave empty — Vite dev server proxies /api/* to localhost:8000
# Production: set to your Render backend URL
# Example: https://resume-analyzer-backend.onrender.com
VITE_API_BASE_URL=https://your-render-backend.onrender.com
