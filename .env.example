# ═══════════════════════════════════════════════════════════════════════════
# Smart Resume Analyzer — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in all required values below
# 3. NEVER commit .env to git (already in .gitignore)
# 4. For production, use strong random values

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED — Application will fail without these
# ═══════════════════════════════════════════════════════════════════════════

# Backend JWT Secret Key (CRITICAL SECURITY)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters, random and unique per deployment
SECRET_KEY=changeme_use_a_strong_random_key_in_production

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
# Required for AI resume analysis and interview kit generation
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL Configuration
# ═══════════════════════════════════════════════════════════════════════════

# PostgreSQL credentials for Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_db_password_here
POSTGRES_DB=resume_ai

# Full database connection string (backend reads this)
# For Docker Compose: Use service name 'db' as hostname
# For local dev: Use localhost
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql://postgres:password@db:5432/resume_ai

# For SQLite (development/testing only):
# DATABASE_URL=sqlite:///./resume_ai.db

# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND — Vite Build Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Backend API URL (baked into frontend bundle at build time)
# IMPORTANT: Set to the PUBLIC URL where users access the backend
# Local development: http://localhost:8000
# Production: https://api.yourdomain.com or https://yourdomain.com/api
VITE_API_BASE_URL=http://localhost:8000

# Frontend URL (used by backend for CORS)
# Set to where users access the frontend UI
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Application Behavior
# ═══════════════════════════════════════════════════════════════════════════

# Application mode: demo | production
APP_MODE=production

# Enable JWT authentication and RBAC
ENABLE_AUTH=true

# Enable rate limiting (recommended for production)
ENABLE_USAGE_LIMITS=true

# Enable analytics tracking
ENABLE_ANALYTICS=false

# Maximum file upload size in bytes (default: 10MB)
# MAX_FILE_BYTES=10485760

# JWT token expiration
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Maximum concurrent workers for batch processing
# MAX_WORKERS=10

# File upload directory
# UPLOAD_DIR=./uploads

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
# [ ] SECRET_KEY is random and 64+ characters
# [ ] POSTGRES_PASSWORD is strong (16+ chars, mixed case, numbers, symbols)
# [ ] GEMINI_API_KEY is valid and has quota
# [ ] VITE_API_BASE_URL points to correct public backend URL
# [ ] APP_MODE=production
# [ ] ENABLE_AUTH=true
# [ ] ENABLE_USAGE_LIMITS=true
# [ ] Database backups are configured
# [ ] HTTPS/TLS is enabled (reverse proxy: nginx/Caddy)
# [ ] Firewall rules limit database port access
# [ ] Logs are being collected and monitored
